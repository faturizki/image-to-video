# Environment Variables for AI Video Generator
# Copy this file to .env and fill in your API keys

# Hugging Face API Key (for image/video generation)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# OpenAI API Key (deprecated - use GEMINI_API_KEY instead)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API Key (for script generation)
GEMINI_API_KEY=your_gemini_api_key_here

# Note: In production/GitHub Actions, these are set via GitHub Secrets
# To test API keys locally: python backend/test_api_keys.py